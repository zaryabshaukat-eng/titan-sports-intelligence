# Application
TITAN_APP_ENV=development
TITAN_LOG_LEVEL=INFO
TITAN_DOCS_ENABLED=true
TITAN_METRICS_ENABLED=true
TITAN_CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# Infrastructure
TITAN_DATABASE_URL=postgresql+asyncpg://titan:titan@localhost:5432/titan
TITAN_REDIS_URL=redis://localhost:6379/0

# Security
# Generate a unique value before any production deployment.
TITAN_SECRET_KEY=local-development-secret-change-before-production

# Optional integration-test database. Docker Compose supplies a suitable value.
# TITAN_TEST_DATABASE_URL=postgresql+asyncpg://titan:titan@localhost:5432/titan
